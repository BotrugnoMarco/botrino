# ===============================
# Discord Bot - Configurazioni
# ===============================

# Token del bot Discord (ottienilo da https://discord.com/developers/applications)
DISCORD_TOKEN="IL_TUO_TOKEN_QUI"

# ID del canale Discord dove inviare i report giornalieri
REPORT_CHANNEL_ID=123456789012345678

# Canali da escludere dai report (separati da virgola)
REPORT_EXCLUDE_CHANNEL_IDS=123456789012345678

# ID del canale Discord dove inviare gli aggiornamenti del bot
UPDATES_CHANNEL_ID=123456789012345678

# ID del canale Discord dove inviare i messaggi di benvenuto
WELCOME_CHANNEL_ID=123456789012345678

# Colore primario per gli embed (es. 0x3498db per blu chiaro)
PRIMARY_COLOR=0x3498db

# Fuso orario per le operazioni pianificate (es. "Europe/Rome")
ZONE="Europe/Rome"

# ===============================
# MySQL Database
# ===============================

MYSQL_HOST="localhost"
MYSQL_USER="il_tuo_utente"
MYSQL_PASSWORD="la_tua_password"
MYSQL_DB="discord_bot"

# ===============================
# Percorsi e script
# ===============================

BOT_DIR=/percorso/al/tuo/bot
BOT_SCRIPT=bot.py
VENV=/percorso/al/tuo/bot/venv/bin/activate

# Webhook Discord per notifiche (start/stop/restart)
WEBHOOK_URL=https://discord.com/api/webhooks/ID/TOKEN

# Username di Ko-fi per il comando !donate
KOFI_USERNAME="il_tuo_username"

# Canali AFK da escludere dal calcolo del tempo di attività (separati da virgola)
AFK_CHANNEL_IDS=123456789012345678,987654321098765432

# =======================
# CONFIGURAZIONE XP
# =======================

XP_PER_MINUTE=3
XP_PER_MESSAGE=2
XP_PER_REACTION=1
XP_FOR_REACTION_RECEIVED=2
BASE_XP_FOR_LEVEL_UP=250
MESSAGE_COOLDOWN=30

# Ruoli assegnati al raggiungimento di un livello.
# Formato: "livello1:id_ruolo1,livello2:id_ruolo2,..."
LEVEL_ROLES="5:ID_RUOLO,15:ID_RUOLO,30:ID_RUOLO,50:ID_RUOLO,75:ID_RUOLO,100:ID_RUOLO"

AFK_MOVE_TIMEOUT_MINUTES=30

# ID degli utenti esclusi dal move AFK (separati da virgola)
AFK_EXCLUDED_USER_IDS="ID_UTENTE1,ID_UTENTE2"

# Canali dove mutarsi non causa lo spostamento in AFK (separati da virgola, lascia vuoto per disabilitare)
AFK_EXEMPT_CHANNEL_IDS=""
